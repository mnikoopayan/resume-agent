# OpenRouter API Configuration
# Get your key from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Knowledge Base Configuration (ChromaDB)
KNOWLEDGE_COLLECTION=knowledge_base
KNOWLEDGE_PATH=./knowledge/chromadb

# Embedder Configuration (OpenRouter only)
OPENROUTER_EMBEDDER_MODEL=openai/text-embedding-3-small

# Reranker (optional, for hybrid search; improves result ordering)
# Get your key from: https://dashboard.cohere.com/api-keys
# COHERE_API_KEY=your-cohere-api-key-here

# Dropbox Configuration
DROPBOX_PATH=./dropbox

# LLM Model Configuration (OpenRouter)
# Available models: https://openrouter.ai/models
# Examples:
#   openai/gpt-4o-mini (default, cost-effective)
#   openai/gpt-4o (more capable)
#   anthropic/claude-3.5-sonnet
#   google/gemini-pro-1.5
LLM_MODEL=openai/gpt-4o-mini

# Gmail Toolkit Configuration
ENABLE_GMAIL_TOOLS=true
GOOGLE_CREDENTIALS_PATH=./google_api_server/credentials.json
GOOGLE_TOKEN_PATH=./google_api_server/token.json

# Gmail Credentials (for SMTP send)
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_PASSWORD=your-app-password

# Gmail Ingestion Sync Configuration
GMAIL_SYNC_QUERY=in:inbox
GMAIL_SYNC_MAX_RESULTS=20
GMAIL_SYNC_UNREAD_ONLY=true
GMAIL_SYNC_DB_PATH=./knowledge/gmail_ingestion.db
GMAIL_ATTACHMENTS_DIR=./dropbox/gmail

# Candidate Pipeline Database
CANDIDATE_DB_PATH=./knowledge/candidates.db

# Analytics Configuration
ANALYTICS_DB_PATH=./knowledge/candidates.db
